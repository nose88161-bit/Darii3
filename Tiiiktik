async function copyText(text) {
  if (navigator.clipboard && window.isSecureContext) {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch (e) {}
  }

  const textarea = document.createElement('textarea');
  textarea.value = text;
  textarea.setAttribute('readonly', '');
  textarea.style.position = 'fixed';
  textarea.style.left = '-9999px';

  document.body.appendChild(textarea);
  textarea.focus();
  textarea.select();
  textarea.setSelectionRange(0, textarea.value.length);

  let copied = false;

  try {
    copied = document.execCommand('copy');
  } catch (e) {
    copied = false;
  }

  document.body.removeChild(textarea);
  return copied;
}

document.addEventListener('click', (e) => {
  document.querySelectorAll('.status-menu').forEach(menu => {
    if (!menu.contains(e.target) && !e.target.classList.contains('menu-btn')) {
      menu.classList.remove('show');
    }
  });
});

document.querySelectorAll('.note-row').forEach(row => {
  const card = row.querySelector('.note-card');
  const check = row.querySelector('.note-check');
  const menuBtn = row.querySelector('.menu-btn');
  const statusMenu = row.querySelector('.status-menu');
  const statusText = row.querySelector('.status-text');
  const options = row.querySelectorAll('.status-option');
  const copyBtn = row.querySelector('.copy-btn');
  const linkName = row.querySelector('.note-link');

  const id = card.dataset.id;
  const firebaseRef = db.ref('links/' + id);

  firebaseRef.on('value', snapshot => {
    const data = snapshot.val() || {};

    check.checked = data.checked === true;
    card.classList.toggle('used', check.checked);

    statusText.textContent = data.status || '';
    statusText.className = 'status-text';

    if (data.status === 'con visitas') {
      statusText.classList.add('green');
    }

    if (data.status === 'sin visitas') {
      statusText.classList.add('red');
    }
  });

  check.addEventListener('change', () => {
    firebaseRef.update({
      checked: check.checked
    });
  });

  menuBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    statusMenu.classList.toggle('show');
  });

  options.forEach(option => {
    option.addEventListener('click', () => {
      const status = option.dataset.status;

      firebaseRef.update({
        status: status
      });

      statusMenu.classList.remove('show');
    });
  });

  copyBtn.addEventListener('click', async () => {
    const textToCopy = linkName.textContent.trim();
    const copied = await copyText(textToCopy);

    copyBtn.classList.remove('copied', 'error');

    if (copied) {
      copyBtn.textContent = 'Copiado';
      copyBtn.classList.add('copied');
    } else {
      copyBtn.textContent = 'Error';
      copyBtn.classList.add('error');
    }

    setTimeout(() => {
      copyBtn.textContent = 'Copiar';
      copyBtn.classList.remove('copied', 'error');
    }, 1200);
  });
});</script>
